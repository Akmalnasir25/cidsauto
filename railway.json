{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
   "deploy": {
     "startCommand": "HEADLESS=true PLAYWRIGHT_BROWSERS_PATH=0 PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 PLAYWRIGHT_EXECUTABLE_PATH=/usr/bin/chromium-browser node server.js",
     "restartPolicyType": "ON_FAILURE",
     "restartPolicyMaxRetries": 10,
     "env": [
       {
         "name": "HEADLESS",
         "value": "true"
       },
       {
         "name": "PLAYWRIGHT_BROWSERS_PATH",
         "value": "0"
       },
       {
         "name": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD",
         "value": "1"
       },
       {
         "name": "PLAYWRIGHT_EXECUTABLE_PATH",
         "value": "/usr/bin/chromium-browser"
       }
     ]
   }
}
